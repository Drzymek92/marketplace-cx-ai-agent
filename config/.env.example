# Add required environment variables here.
# Secrets only — all non-secret runtime behavior lives in config/config.yaml.
#
# LLM gateway — any OpenAI-compatible endpoint (set base URL, model, and key).
LLM_BASE_URL="https://api.openai.com/v1"
LLM_MODEL="gpt-4o-mini"
LLM_API_KEY=
# Optional — embedding model used by the semantic response cache.
LLM_EMBED_MODEL="text-embedding-3-small"
